# Postgres connection (same database the Python scraper writes to)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# HTTP port
PORT=4000

# CORS: comma-separated allowed origins, or * for any (dev).
CORS_ORIGIN=*

# --- POST /ingest/trigger shells out to the Python pipeline ---
# Path to the Python interpreter that has the scraper deps installed.
PYTHON_BIN=../scraper/venv/bin/python
# Directory the pipeline runs from (where `python -m src.pipeline` resolves).
SCRAPER_DIR=../scraper
# Set to "false" on hosts where the scraper isn't co-located (then trigger
# returns 501 and you run ingestion via a separate cron/job instead).
INGEST_ENABLED=true
