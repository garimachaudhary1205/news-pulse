# Postgres connection string (Supabase / Neon / Railway / local).
# Local example: postgresql://postgres:postgres@localhost:5432/newspulse
# Supabase example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/newspulse

# --- Optional tuning (sensible defaults applied if unset) ---

# Cosine-similarity threshold above which two articles are considered the same topic.
CLUSTER_SIMILARITY_THRESHOLD=0.30

# Max articles to fetch full body text for per run (politeness / speed cap).
MAX_FULL_FETCH=60

# Per-request timeout (seconds) when fetching article pages.
FETCH_TIMEOUT=12

# How many of the most recent articles to feed into the clustering step.
CLUSTER_WINDOW=400
